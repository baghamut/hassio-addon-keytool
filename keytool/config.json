{
  "name": "Keytool Keystore Generator",
  "version": "1.0.10",
  "slug": "keytool",
  "description": "Generates PKCS12 keystores from /ssl certs. Auto-imports to UniFi.",
  "arch": ["armhf", "armv7", "aarch64", "amd64", "i386"],
  "init": false,
  "startup": "application",
  "boot": "auto",
  "map": ["ssl:rw", "share:rw"],
  "options": {
    "password": "Password",
    "unifi_import": true,
    "unifi_pass": "aircontrolenterprise",
    "unifi_alias": "unifi"
  },
  "schema": {
    "password": "str",
    "unifi_import": "bool",
    "unifi_pass": "str",
    "unifi_alias": "str?"
  },
  "ports": {
    "8080/tcp": null
  }
}
